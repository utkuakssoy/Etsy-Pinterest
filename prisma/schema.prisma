generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  name               String?
  imageUrl           String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  etsyShops          EtsyShop[]
  pinterestAccounts  PinterestAccount[]
  aiSeoGenerations   AiSeoGeneration[]
  pinDrafts          PinDraft[]
  scheduledPins      ScheduledPin[]
}

model EtsyShop {
  id           String        @id @default(cuid())
  userId       String
  etsyShopId   String        @unique
  name         String
  url          String?
  avatarUrl    String?
  connectedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings     EtsyListing[]
}

model EtsyListing {
  id                  String              @id @default(cuid())
  shopId              String
  etsyListingId       String              @unique
  title               String
  description         String              @db.Text
  price               Decimal             @db.Decimal(10, 2)
  currency            String              @default("USD")
  images              String[]
  tags                String[]
  category            String?
  listingUrl          String
  status              String              @default("active")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  shop                EtsyShop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  aiSeoGenerations    AiSeoGeneration[]
  pinDrafts           PinDraft[]
  analyticsSnapshots  PinAnalyticsSnapshot[]
}

model PinterestAccount {
  id                 String           @id @default(cuid())
  userId             String
  pinterestAccountId String           @unique
  username           String
  profileUrl         String?
  connectedAt        DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  boards             PinterestBoard[]
}

model PinterestBoard {
  id                 String           @id @default(cuid())
  accountId          String
  pinterestBoardId   String           @unique
  name               String
  description        String?
  url                String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  account            PinterestAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pinDrafts          PinDraft[]
}

model AiSeoGeneration {
  id        String      @id @default(cuid())
  userId    String
  listingId String
  input     Json
  output    Json
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   EtsyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model PinDraft {
  id                  String                  @id @default(cuid())
  userId              String
  productId           String
  boardId             String?
  title               String
  description         String                  @db.Text
  destinationUrl      String
  imageUrl            String
  status              String                  @default("draft")
  scheduledAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product             EtsyListing             @relation(fields: [productId], references: [id], onDelete: Cascade)
  board               PinterestBoard?         @relation(fields: [boardId], references: [id], onDelete: SetNull)
  scheduledPins       ScheduledPin[]
  analyticsSnapshots  PinAnalyticsSnapshot[]
}

model ScheduledPin {
  id          String    @id @default(cuid())
  userId      String
  pinDraftId  String
  scheduledAt DateTime
  status      String    @default("scheduled")
  error       String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinDraft    PinDraft  @relation(fields: [pinDraftId], references: [id], onDelete: Cascade)
}

model PinAnalyticsSnapshot {
  id             String      @id @default(cuid())
  productId      String
  pinDraftId     String?
  impressions    Int         @default(0)
  outboundClicks Int         @default(0)
  saves          Int         @default(0)
  ctr            Decimal     @default(0) @db.Decimal(6, 4)
  date           DateTime
  createdAt      DateTime    @default(now())
  product        EtsyListing @relation(fields: [productId], references: [id], onDelete: Cascade)
  pinDraft       PinDraft?   @relation(fields: [pinDraftId], references: [id], onDelete: SetNull)
}
